# ── Server Config ──────────────────────────────────────────────────────────────
ENV=production
APP_DEBUG=False

# ── Security ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=gere_com_openssl_rand_hex_32
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=gere_com_python_fernet_generate_key
METRICS_TOKEN=token_para_endpoint_metrics

# ── Database ─────────────────────────────────────────────────────────────
DB_USER=admin
DB_PASSWORD=senha_forte_aqui
DB_NAME=auto_tech_lith

# ── Redis ───────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=senha_forte_aqui

# ── Evolution API ───────────────────────────────────────────────────────
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_SERVER_URL=https://seu-dominio-evolution.com
EVOLUTION_INSTANCE_NAME=default
EVOLUTION_DB_USER=postgresql
EVOLUTION_DB_PASSWORD=senha_forte_aqui
EVOLUTION_DB_NAME=evolution

# ── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Telegram ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── Webhook ─────────────────────────────────────────────────────────────
VERIFY_TOKEN=token_secreto_aqui
PUBLIC_URL=https://seu-dominio.com

# ── CORS ───────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["https://seu-dominio.com"]

# ── SMTP ──────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=sua_senha_de_app

# ── pgAdmin (apenas dev) ────────────────────────────────────────────
PGADMIN_EMAIL=admin@seudominio.com
PGADMIN_PASSWORD=senha_forte_aqui

# ── CI/CD Deploy (GitHub Actions Secrets) ───────────────────────────
# Configure estes como GitHub Secrets (NÃO no .env):
# VPS_HOST=ip_ou_dominio_do_vps
# VPS_USER=root
# VPS_SSH_KEY=<chave_privada_ssh>

# ── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
