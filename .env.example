# ============================================\n# AUTO TECH LITH - CUSTOMER SERVICE AGENT\n# Environment Configuration\n# ============================================\n\n# ============ CORE SETTINGS ============\nENV=development\nDEBUG=True\nLOG_LEVEL=INFO\n\n# ============ DATABASE ============\nDATABASE_URL=postgresql://user:password@localhost:5432/auto_tech_lith\nDATABASE_ECHO=False\nDATABASE_POOL_SIZE=20\n\n# ============ OPENAI / LLM ============\nOPENAI_API_KEY=sk-\nOPENAI_MODEL=gpt-4o-mini\nOPENAI_TEMPERATURE=0.7\nOPENAI_MAX_TOKENS=2000\n\n# ============ WHATSAPP / EVOLUTION ============\nEVOLUTION_API_URL=http://localhost:8080\nEVOLUTION_API_KEY=your-evolution-api-key\nEVOLUTION_INSTANCE_NAME=auto-tech-lith\nWHATSAPP_NUMBER=5511987654321\n\n# ============ TELEGRAM ============\nTELEGRAM_BOT_TOKEN=your-telegram-bot-token\nTELEGRAM_CHAT_ID=your-chat-id\nTELEGRAM_ADMIN_ID=your-admin-id\n\n# ============ NGROK ============\nNGROK_AUTH_TOKEN=your-ngrok-auth-token\nNGROK_WEBHOOK_URL=http://localhost:8000/webhooks\n\n# ============ API ============\nAPI_HOST=0.0.0.0\nAPI_PORT=8000\nAPI_TITLE=Auto Tech Lith Agent API\nAPI_VERSION=1.0.0\nAPI_CORS_ORIGINS=[\"*\"]\n\n# ============ JWT / SECURITY ============\nSECRET_KEY=your-super-secret-key-change-this-in-production\nALGORITHM=HS256\nACCESS_TOKEN_EXPIRE_MINUTES=480\n\n# ============ EMAIL (Optional) ============\nSMTP_SERVER=smtp.gmail.com\nSMTP_PORT=587\nSMTP_USER=your-email@gmail.com\nSMTP_PASSWORD=your-email-password\nSMTP_FROM_EMAIL=noreply@autotechlith.com\n\n# ============ BUSINESS SETTINGS ============\nCOMPANY_NAME=Auto Tech Lith\nBUSINESS_HOURS_START=09:00\nBUSINESS_HOURS_END=18:00\nTIMEZONE=America/Sao_Paulo\n\n# ============ MEETING SETTINGS ============\nBRIEFING_DURATION_MINUTES=60\nPROPOSAL_DURATION_MINUTES=90\nMEETING_BUFFER_MINUTES=30\n\n# ============ PROMPTS & SYSTEM ============\nSYSTEM_PROMPT_LANGUAGE=pt-BR\nAGENT_NAME=Auto Tech Lith Assistant\nCOMPANY_DESCRIPTION=Solucoes de automacao com IA para empresas"
