# ============================================
# AUTO TECH LITH - CUSTOMER SERVICE AGENT
# Environment Configuration — PRODUCTION
# ============================================
# Copy this file to .env and fill in all values before deploying.
# No default values are safe for production — configure ALL fields below.

# ============ CORE SETTINGS ============
ENV=production
DEBUG=False
LOG_LEVEL=INFO

# ============ DATABASE ============
# PostgreSQL (used in production via docker-compose)
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}
DB_USER=admin
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=auto_tech_lith

# ============ REDIS ============
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ============ OPENAI / LLM ============
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ============ WHATSAPP / EVOLUTION ============
# URL pública da VPS onde a Evolution API será exposta (ex: via proxy reverso no Dokploy)
EVOLUTION_SERVER_URL=https://evolution.seu-dominio.com
EVOLUTION_API_URL=http://evolution_api:8080
EVOLUTION_API_KEY=CHANGE_THIS_EVOLUTION_API_KEY
EVOLUTION_INSTANCE_NAME=default
# Token secreto para webhooks do WhatsApp
EVOLUTION_WEBHOOK_TOKEN=CHANGE_THIS_WEBHOOK_TOKEN

# ============ TELEGRAM ============
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ============ API ============
API_PORT=8000
PUBLIC_URL=https://seu-dominio.com

# CORS — JSON array com os domínios permitidos
BACKEND_CORS_ORIGINS=["https://seu-dominio.com","https://www.seu-dominio.com"]

# ============ JWT / SECURITY ============
# Gere com: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_SECRET_KEY_openssl_rand_hex_32

# ============ ENCRYPTION (AI Config Vault) ============
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_THIS_FERNET_KEY

# ============ POSTGRES ADMIN (opcional — só dev) ============
PGADMIN_EMAIL=admin@seu-dominio.com
PGADMIN_PASSWORD=CHANGE_THIS_PGADMIN_PASSWORD

# ============ BUSINESS SETTINGS ============
COMPANY_NAME=Auto Tech Lith
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
TIMEZONE=America/Sao_Paulo

# ============ WEBHOOK VERIFICATION ============
# Token usado para verificar requisições de webhook
VERIFY_TOKEN=CHANGE_THIS_VERIFY_TOKEN

# Evolution API Database (separado do banco principal)
EVOLUTION_DB_USER=postgresql
EVOLUTION_DB_PASSWORD=sua_senha_aqui
EVOLUTION_DB_NAME=evolution

# CORS — URL pública do frontend em produção (obrigatório)
BACKEND_CORS_ORIGINS=["https://seudominio.com"]
